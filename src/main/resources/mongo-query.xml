<?xml version="1.0" encoding="UTF-8"?>
<queries>
    <query id="findAllApiKeys">
        <collection>api_keys</collection>
        <criteria>{}</criteria>
    </query>
    <query id="findApiKeysWithFilter">
        <collection>api_keys</collection>
        <match>
            service = #{service}
            created_at gte #{from}
            created_at lte #{to}
        </match>
    </query>
</queries>
