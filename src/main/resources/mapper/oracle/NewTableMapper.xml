<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.amos.service.repository.oracle.mapper.NewTableMapper">

    <select id="selectAll" resultType="map">
        SELECT *
        FROM NEWTABLE
    </select>

    <select id="searchNewTable" resultType="map">
        SELECT *
        FROM NEWTABLE
        <where>
            <if test="param1 != null and param1 != ''">
                AND COLUMN1 = #{param1}
            </if>
            <if test="param2 != null">
                AND COLUMN2 = #{param2}
            </if>
        </where>
    </select>

</mapper>
