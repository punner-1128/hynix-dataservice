<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.amos.service.mapper.NewTableMapper">

    <select id="selectAllNewTable" resultType="map">
        SELECT *
        FROM NEWTABLE
    </select>

    <select id="selectNewTable" resultType="map">
        SELECT *
        FROM NEWTABLE n
        WHERE n.COLUMN1 != #{column1}
        AND n.COLUMN2 > #{column2}
    </select>

</mapper>
