<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.amos.service.mapper.LogMapper">

    <select id="selectLogTable" resultType="map">
        SELECT *
        FROM LOGTABLE l
        WHERE l.LOG_LEVEL = #{logLevel}
    </select>

</mapper>
