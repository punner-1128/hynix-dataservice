<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.amos.service.mapper.UserMapper">

    <select id="selectUserTable" resultType="map">
        SELECT *
        FROM USERTABLE u
        WHERE u.USER_ID = #{userId}
    </select>

</mapper>
